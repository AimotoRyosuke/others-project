# Development Dockerfile - simplified approach
FROM node:18-alpine AS base

# Install required dependencies
RUN apk add --no-cache libc6-compat

WORKDIR /app

# Enable corepack to use yarn
RUN corepack enable

# Copy all package files and install dependencies
# For development, we copy everything to make workspace resolution work
COPY package.json yarn.lock .yarnrc.yml ./
COPY .yarn ./.yarn

# Copy all workspace package.json files
COPY apps/ ./apps/
COPY packages/ ./packages/

# Install dependencies
RUN yarn install --immutable

# Web development stage
FROM base AS web
WORKDIR /app
EXPOSE 3000
CMD ["yarn", "workspace", "@others/web", "dev"]

# API development stage  
FROM base AS api
WORKDIR /app
EXPOSE 4000
CMD ["yarn", "workspace", "@others/api", "dev"]

# Dev Container stage
FROM base AS dev
WORKDIR /app

# Install additional development tools
RUN apk add --no-cache \
    git \
    openssh-client \
    curl \
    wget \
    bash \
    zsh \
    nano \
    vim

# Install global tools
RUN yarn global add @nestjs/cli prisma

# Create non-root user
RUN addgroup -g 1000 node && adduser -u 1000 -G node -s /bin/sh -D node
USER node

EXPOSE 3000 4000
CMD ["sleep", "infinity"]