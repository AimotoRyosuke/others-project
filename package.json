{
  "name": "others-project-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:ts": "eslint \"**/*.{ts,tsx}\" --report-unused-disable-directives",
    "lint:js-check": "eslint \"**/*.{js,jsx}\" --report-unused-disable-directives",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:coverage:merge": "yarn test:coverage && node scripts/merge-coverage.js",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml}\"",
    "type-check": "turbo run type-check",
    "firebase:emulators": "firebase emulators:start --only auth",
    "firebase:emulators:ui": "firebase emulators:start --only auth,ui",
    "dev:with-emulators": "concurrently --names \"firebase,api,web\" --prefix-colors \"blue,green,cyan\" \"yarn firebase:emulators\" \"yarn workspace @others/api dev\" \"yarn workspace @others/web dev\""
  },
  "dependencies": {
    "react": "19.1.1",
    "react-dom": "19.1.1"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.0",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.36.0",
    "@rollup/rollup-darwin-arm64": "^4.52.2",
    "@types/babel__generator": "^7.27.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/supertest": "^6.0.2",
    "concurrently": "^9.2.1",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "firebase-tools": "^14.17.0",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "turbo": "latest",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "webpack": "^5.0.0"
  },
  "resolutions": {
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "typescript": "^5.7.3"
  },
  "packageManager": "yarn@4.10.3",
  "engines": {
    "node": ">=18.0.0",
    "yarn": ">=4.0.0"
  }
}
