{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "types": ["./packages/types/src"],
      "ui": ["./packages/ui/src"],
      "validation": ["./packages/validation/src"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
